{
    "compilerOptions": {
        "lib": ["ES2020"],
        "target": "ES2020",
        "module": "ES2020",
        
        "moduleResolution": "node",
        "rootDir": "./",
        "baseUrl": "./",

        "outDir": "scripts",
        "removeComments": true,
        "allowJs": true,

        "strict": true,
        "noImplicitThis": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "skipLibCheck": true
    },
    "include": ["entry.ts", "types.d.ts"]
}
